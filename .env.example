# API OAuth (server — copier vers .env à la racine, ne pas committer)
PORT=8787
FRONTEND_URL=http://localhost:5173
OAUTH_REDIRECT_URI=http://localhost:8787/auth/google/callback

# Optionnel : chemin explicite vers le JSON OAuth
# GOOGLE_OAUTH_CLIENT_FILE=./client_secret_....apps.googleusercontent.com.json

# Fichier des tokens (refresh) — créé automatiquement après la première connexion
# GSC_TOKEN_FILE=./gsc-oauth-tokens.json
